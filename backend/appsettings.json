{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=securescope.db"
  },
  "PcScanning": {
    "UseDemoData": false
  },
  "WebsiteScanning": {
    "EnforceAllowlist": false,
    "AllowedHosts": [
      "example.com",
      "www.example.com"
    ],
    "MaxRedirects": 3,
    "TimeoutSeconds": 10
  },
  "Frontend": {
    "AllowedOrigins": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
